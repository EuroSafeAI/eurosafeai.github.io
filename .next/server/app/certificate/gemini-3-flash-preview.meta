{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/certificate/layout,_N_T_/certificate/[slug]/layout,_N_T_/certificate/[slug]/page,_N_T_/certificate/gemini-3-flash-preview"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/certificate/$d$slug/__PAGE__",
    "/certificate/$d$slug",
    "/certificate",
    "/_index",
    "/_head"
  ]
}